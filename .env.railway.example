# ─────────────────────────────────────────────────────────────────────────────
# Variables Railway — à copier dans le dashboard Railway de chaque service.
# NE PAS committer ce fichier avec de vraies valeurs.
# ─────────────────────────────────────────────────────────────────────────────

# ════════════════════════════════════════════════════════════════════════════
# SERVICE : backend_django
# (Dashboard Railway → service backend → Variables)
# ════════════════════════════════════════════════════════════════════════════

# Générer : python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=REMPLACER_PAR_CLE_FORTE

DEBUG=False

# Railway injecte $PORT automatiquement — ne pas définir PORT manuellement.

# Renseigné après le 1er déploiement du backend (URL Railway générée).
# Format : monprojet-backend.up.railway.app  (sans https://)
ALLOWED_HOSTS=localhost,backend,DOMAINE_BACKEND_RAILWAY

# ── Base de données ───────────────────────────────────────────────────────
# Valeurs fournies automatiquement par le plugin PostgreSQL Railway.
# Dans Railway : cliquer sur le service PostgreSQL → Connect → copier les valeurs.
DB_NAME=railway
DB_USER=postgres
DB_PASSWORD=FOURNI_PAR_RAILWAY_POSTGRESQL
DB_HOST=FOURNI_PAR_RAILWAY_POSTGRESQL
DB_PORT=5432

# ── CORS / CSRF ───────────────────────────────────────────────────────────
# URL publique du service frontend Railway (connue après déploiement frontend).
# Exemple : https://monprojet-frontend.up.railway.app
CORS_ALLOWED_ORIGINS=https://DOMAINE_FRONTEND_RAILWAY
CSRF_TRUSTED_ORIGINS=https://DOMAINE_FRONTEND_RAILWAY

# ── QR codes des documents officiels ─────────────────────────────────────
# URL publique du service BACKEND Railway (pour les QR codes des certificats).
# Exemple : https://monprojet-backend.up.railway.app
RCCM_VERIFICATION_BASE_URL=https://DOMAINE_BACKEND_RAILWAY


# ════════════════════════════════════════════════════════════════════════════
# SERVICE : frontend
# (Dashboard Railway → service frontend → Variables)
# ════════════════════════════════════════════════════════════════════════════

# ── BACKEND_URL (variable RUNTIME — lue par le proxy Express au démarrage) ──
# URL interne ou publique du service backend Django.
# OBLIGATOIRE si REACT_APP_API_URL est vide (architecture proxy).
# Le proxy Express redirige /api/* vers cette URL.
# Exemple : https://monprojet-backend.up.railway.app
BACKEND_URL=https://DOMAINE_BACKEND_RAILWAY

# ── REACT_APP_API_URL (variable BUILD — baked dans le bundle React) ──────────
# ATTENTION : cette variable est injectée au BUILD — tout changement déclenche
# un rebuild complet du frontend.
#
# OPTION A (proxy — recommandé) : laisser vide ou ne pas définir.
#   → React utilise des URLs relatives (/api/...)
#   → Proxy Express reçoit les requêtes et les forward vers BACKEND_URL
#   → Pas de problème CORS (même origin navigateur)
#   REACT_APP_API_URL=
#
# OPTION B (direct — sans proxy) : renseigner l'URL backend.
#   → React appelle directement le backend depuis le navigateur
#   → Requiert CORS_ALLOW_ALL_ORIGINS=True ou CORS_ALLOWED_ORIGINS correct
#   → BACKEND_URL non utilisé (proxy bypassé)
#   REACT_APP_API_URL=https://DOMAINE_BACKEND_RAILWAY
#
# Par défaut (.env.production commité) : OPTION A active (REACT_APP_API_URL vide).
# Décommenter et renseigner ci-dessous UNIQUEMENT pour l'OPTION B :
# REACT_APP_API_URL=https://DOMAINE_BACKEND_RAILWAY
